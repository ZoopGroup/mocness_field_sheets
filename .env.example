# MOCNESS Field Sheets Environment Variables
# Copy this file to .env and update the values as needed

# Directory containing input images (form and notes PNG files)
INPUT_DIR=input

# Directory where extracted JSON files will be saved
OUTPUT_DIR=output

# OpenAI API Key for GPT-4o model (required)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional: Debug settings
DEBUG=false
LOG_LEVEL=info
